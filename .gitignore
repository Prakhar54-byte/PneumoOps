# Python cache and build outputs
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Local tool and editor state
.codex
.codex/
.DS_Store
.idea/
.vscode/
.huggingface-spaces/

# Environment and secrets
.env
.env.*
*.local

# Runtime logs and temp files
*.log
*.tmp
*.temp

# Hugging Face and dataset cache
data/hf_cache/
data/*.npz
.cache/

# Generated screenshots and local demo assets
Screenshot_*.png

# Large/generated model artifacts
models/*.pth
models/*.onnx
models/*_report.json
models/*_history.json
models/*_stats.json
models/*.csv
models/plots/
models/realworld_densenet121/
models/realworld_efficientnet_b0/

# Keep repo structure files available if directories would otherwise disappear
!models/.gitkeep
!models/plots/.gitkeep
!data/.gitkeep
